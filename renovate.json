{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "custom.regex"
  ],
  "labels": [
    "dependencies",
    "docker-images",
    "provider-box"
  ],
  "dependencyDashboard": true,
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "rangeStrategy": "pin",
  "separateMajorMinor": true,
  "separateMultipleMajor": true,
  "rebaseWhen": "behind-base-branch",
  "commitMessageAction": "Update",
  "commitMessageTopic": "container image",
  "commitMessageExtra": "{{depName}} to {{newValue}}",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "^config/provider-box\\.env\\.example$"
      ],
      "matchStrings": [
        "^[A-Z0-9_]+_IMAGE=\"?(?<depName>[^\":\\s]+(?:/[^\":\\s]+)*):(?<currentValue>[^\"\\s]+)\"?$"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Group all Provider Box image updates into one PR",
      "matchManagers": [
        "custom.regex"
      ],
      "matchDatasources": [
        "docker"
      ],
      "groupName": "Provider Box container images",
      "groupSlug": "provider-box-container-images"
    },
    {
      "description": "Keep major image updates separate for manual review",
      "matchManagers": [
        "custom.regex"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "Provider Box major container images",
      "groupSlug": "provider-box-major-container-images",
      "addLabels": [
        "breaking-change-review"
      ]
    },
    {
      "description": "Automerge is disabled for image updates",
      "matchManagers": [
        "custom.regex"
      ],
      "matchDatasources": [
        "docker"
      ],
      "automerge": false
    }
  ]
}
